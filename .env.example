# ── CMS Postgres (Payload) ──
# Ideal: dedicated Supabase project "zali-site" (needs a free project slot or Pro plan).
# Interim: same Supabase host as board, but CMS tables live in isolated `cms` schema
# (board uses `public` only — Payload is configured with schemaName: cms).
#
# Dashboard → zali-site project (or interim host) → Database → Session pooler → URI (port 5432)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[YOUR-DB-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# openssl rand -hex 32
PAYLOAD_SECRET=change-me-to-a-long-random-string

# Public site URL (no trailing slash)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Task board API (landing preview)
BOARD_API_URL=https://board.zali.so

# false = faster dev (no schema push prompts). true briefly after collection schema changes.
PAYLOAD_DB_PUSH=false

# Waitlist — Mautic when ready (placeholder mode works without any of these)
# MAUTIC_FORM_SUBMIT_URL=https://mautic.yourdomain.com/form/submit?formId=1
# MAUTIC_FORM_NAME=zali_waitlist
# MAUTIC_FORM_ID=1
